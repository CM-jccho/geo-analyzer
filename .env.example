# ── LLM 노출 + 콘텐츠 분석 ──
# Anthropic(Claude): 콘텐츠 분석 + AI 노출 테스트의 기본 프로바이더. 없으면 두 단계 모두 skip.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# 선택: 추가 LLM 프로바이더 (있는 것만 자동 활성화)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── 문의 메일 발송 (SMTP) ──
# 설정 시 문의가 jaechul.cho@gmail.com 으로 메일 발송됨. 없으면 서버 로그에만 기록.
# Gmail 예시: 2단계 인증 후 "앱 비밀번호" 발급해서 SMTP_PASS에 입력
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# ── 잡 큐 ──
# 설정 시 BullMQ(Redis)로 처리, 없으면 인메모리. 예: redis://127.0.0.1:6379
REDIS_URL=
GEO_CONCURRENCY=3
