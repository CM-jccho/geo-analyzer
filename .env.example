# ── LLM 노출 + 콘텐츠 분석 ──
# Anthropic(Claude): 콘텐츠 분석 + AI 노출 테스트의 기본 프로바이더. 없으면 두 단계 모두 skip.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# 선택: 추가 LLM 프로바이더 (있는 것만 자동 활성화)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── 문의 메일 발송 (SMTP) ──
# 설정 시 문의가 jaechul.cho@gmail.com 으로 메일 발송됨. 없으면 서버 로그에만 기록.
# Gmail 예시: 2단계 인증 후 "앱 비밀번호" 발급해서 SMTP_PASS에 입력
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# ── 결과 공유 영속화 + 레이트리밋 (Vercel KV / Upstash Redis) ──
# Vercel에서 KV 연동 시 자동 주입. 없으면 인메모리로 폴백(공유 링크 비영속, 레이트리밋은 인스턴스별).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# 레이트리밋 한도(분석/문의) — 윈도우(초)당 허용 횟수
ANALYZE_RATE_LIMIT=5
ANALYZE_RATE_WINDOW=600
CONTACT_RATE_LIMIT=3
CONTACT_RATE_WINDOW=600
# AutoSec Scanner — 플랜별 1일 스캔 횟수 제한
SCAN_DAILY_LIMIT=3
PRO_SCAN_DAILY_LIMIT=50
ENT_SCAN_DAILY_LIMIT=1000
# 플랜 키(쉼표구분) — x-plan-key 헤더로 전달 시 해당 플랜 적용
PRO_PLAN_KEYS=
ENTERPRISE_PLAN_KEYS=
# 실제 스캔 엔진 사용 시: real (기본 mock). 서버/워커에 엔진 필요.
SCANNER_MODE=mock
TRIVY_BIN=trivy
ZAP_API_URL=
ZAP_API_KEY=

# ── 잡 큐 ──
# 설정 시 BullMQ(Redis)로 처리, 없으면 인메모리. 예: redis://127.0.0.1:6379
REDIS_URL=
GEO_CONCURRENCY=3
